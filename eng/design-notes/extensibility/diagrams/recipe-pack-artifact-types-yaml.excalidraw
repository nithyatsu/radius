      "updated": 1781568451414,
      "link": null,
      "locked": false,
      "text": "resource defaultK8s 'Radius.Core/recipePacks@..' = {\n  properties: { recipes: {\n    // recipeLocation = FIXED, constructable pattern:\n    //   contrib//recipes/<category>/<type>/<platform>?ref=<ver>\n    'Radius.Compute/containers': {\n      recipeLocation: 'contrib//recipes/compute/containers/kubernetes?ref=v0.48'\n    }\n    'Radius.Security/secrets': { '...security/secrets/kubernetes...' }\n    'Radius.Storage/volumes':  { '...storage/volumes/kubernetes...' }\n  } }\n}",
