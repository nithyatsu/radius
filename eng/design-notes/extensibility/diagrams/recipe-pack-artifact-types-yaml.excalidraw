    {
      "id": "tension-text",
      "type": "text",
      "x": 665.0060820194874,
      "y": 536.1763785651337,
      "width": 540.8662109375,
      "height": 367.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
